# ralph/Dockerfile.agent
# Isolated container for ralph subagents (supervisor and implementers).
# Build: docker build -f ralph/Dockerfile.agent -t ralph-agent .
# The repo is mounted at /workspace at runtime — never baked in.

FROM python:3.12-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Install Copilot CLI (github/copilot-cli — the new standalone CLI, not the deprecated gh extension)
RUN ARCH=$(uname -m) \
    && case "$ARCH" in \
         x86_64)  TARBALL="copilot-linux-x64.tar.gz" ;; \
         aarch64) TARBALL="copilot-linux-arm64.tar.gz" ;; \
         *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac \
    && curl -fsSL "https://github.com/github/copilot-cli/releases/latest/download/${TARBALL}" \
       -o /tmp/copilot.tar.gz \
    && mkdir /tmp/cop \
    && tar -xzf /tmp/copilot.tar.gz -C /tmp/cop \
    && find /tmp/cop -type f -name "copilot" -exec install -m755 {} /usr/local/bin/copilot \; \
    && rm -rf /tmp/cop /tmp/copilot.tar.gz \
    && copilot --version

# Install Playwright browsers (needed for scraper smoke tests inside container)
RUN pip install --no-cache-dir playwright && playwright install --with-deps chromium

WORKDIR /workspace

# At runtime the host repo is bind-mounted here.
# Dependencies are installed fresh each run via uv sync.
ENTRYPOINT ["bash", "-c", "uv sync --quiet 2>/dev/null; exec \"$@\"", "--"]
CMD ["bash"]
