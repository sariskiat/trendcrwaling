# TikTok Scrapers
# -----------------
# Playwright-based scraper (requires cookies exported from browser)
TT_COOKIES_FILE=/path/to/tiktok_cookies.txt

# TikTok-Api library scraper (requires ms_token)
TT_MS_TOKEN=your_ms_token_here

# TikAPI.io managed API (requires API key from tikapi.io)
TIKAPI_KEY=your_tikapi_key_here

# Apify Clockworks managed API (requires API token from apify.com)
APIFY_TOKEN=your_apify_token_here

# Instagram Scraper
# -----------------
IG_COOKIES_FILE=/path/to/instagram_cookies.txt

# Facebook Scraper
# ----------------
FB_COOKIES_FILE=/path/to/facebook_cookies.txt

# Image Analysis
# --------------
OPENAI_API_KEY=your_openai_api_key_here